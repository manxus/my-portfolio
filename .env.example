ADMIN_USER=admin
ADMIN_PASS=changeme

# Steam Web API — https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key
STEAM_ID=your_steam_id

# Decap CMS (production) — set in Vercel Project → Environment Variables
# GitHub OAuth App: callback URL = same value as COMPLETE_URL (e.g. https://your-app.vercel.app/api/complete)
ORIGIN=https://your-app.vercel.app
COMPLETE_URL=https://your-app.vercel.app/api/complete
ADMIN_PANEL_URL=https://your-app.vercel.app/admin/
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
